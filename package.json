{
  "name": "treezip",
  "version": "1.0.0",
  "description": "Compressed tree output for AI-optimized codebase summaries",
  "type": "module",
  "bin": {
    "treezip": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yigitkonur/treezip.git"
  },
  "homepage": "https://github.com/yigitkonur/treezip",
  "bugs": {
    "url": "https://github.com/yigitkonur/treezip/issues"
  },
  "author": "Yigit Konur",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "tree",
    "compressed",
    "ai",
    "codebase",
    "cli",
    "directory",
    "structure",
    "llm",
    "context",
    "brace-expansion",
    "npx"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  }
}
